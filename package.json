{
  "name": "pinpinto",
  "version": "1.5.9",
  "description": "",
  "main": "background.js",
  "scripts": {
    "dev": "vite",
    "icon:build": "node resize_icons.js",
    "typecheck": "tsc --noEmit",
    "test:release": "node --test scripts/tests/*.test.mjs",
    "test:e2e": "node scripts/build-e2e.mjs && playwright test",
    "audit:dependencies": "node scripts/dependency-audit.mjs",
    "audit:production": "node scripts/production-audit.mjs",
    "verify": "tsc --noEmit && node --test scripts/tests/*.test.mjs && vite build",
    "release:preflight": "node scripts/release-preflight.mjs",
    "build": "vite build && node scripts/package-artifact.mjs --browser=chrome --source=dist --format=zip",
    "build:browsers": "node scripts/build-browsers.mjs",
    "release": "node scripts/release.mjs",
    "release:force": "node scripts/release.mjs --force"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.33.4",
  "type": "module",
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.3.0",
    "@playwright/test": "1.61.1",
    "@types/chrome": "^0.1.37",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "jszip": "^3.10.1"
  }
}
